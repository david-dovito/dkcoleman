# Environment Variables Template
# Copy this file to .env.local and fill in your values

# ============================================
# REQUIRED - Neon PostgreSQL Database
# ============================================
# Get from console.neon.tech after creating a project

DATABASE_URL=postgresql://user:password@ep-xxx.us-east-2.aws.neon.tech/neondb?sslmode=require

# ============================================
# OPTIONAL - Google Analytics 4
# ============================================

NEXT_PUBLIC_GA_ID=G-

# ============================================
# OPTIONAL - Admin Authentication
# ============================================

# Cloudflare Worker URL (for Telegram login)
NEXT_PUBLIC_WORKER_URL=https://your-worker.workers.dev
NEXT_PUBLIC_TELEGRAM_BOT_NAME=YOUR_BOT_NAME

# JWT secret for admin API route auth
JWT_SECRET=your-jwt-secret-here

# ============================================
# OPTIONAL - Meeting Scheduling (n8n)
# ============================================

N8N_MEETING_WEBHOOK_URL=https://your-n8n.com/webhook/meeting-request
N8N_WEBHOOK_SECRET=random-secret-string

# ============================================
# LEGACY - Notion CMS (remove after migration)
# ============================================

NOTION_TOKEN=
NOTION_DATABASE_ID=
NOTION_RESOURCES_DATABASE_ID=
NOTION_RESUME_PAGE_ID=
NOTION_PROJECTS_DATABASE_ID=
NOTION_ABOUT_DATABASE_ID=
NOTION_RESUME_NARRATIVE_DATABASE_ID=
