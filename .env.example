# Environment Variables Template
# Copy this file to .env.local and fill in your values

# ============================================
# REQUIRED - Neon Postgres (content source of truth)
# ============================================
# Pooled connection string from the Neon dashboard
DATABASE_URL=postgresql://user:pass@host-pooler.region.aws.neon.tech/neondb?sslmode=require

# ============================================
# REQUIRED - Admin CMS (/admin)
# ============================================
# Password to sign in to the CMS
ADMIN_PASSWORD=
# Secret used to sign the admin session cookie (any long random string).
# Falls back to JWT_SECRET if unset.
ADMIN_SECRET=

# ============================================
# LEGACY - Notion (still used by resume/about until fully migrated)
# ============================================
NOTION_TOKEN=
NOTION_DATABASE_ID=your_blog_database_id_32_characters
NOTION_RESOURCES_DATABASE_ID=your_resources_database_id_32_chars
NOTION_RESUME_PAGE_ID=your_resume_page_id_32_characters
NOTION_PROJECTS_DATABASE_ID=your_projects_database_id_32_chars
NOTION_ABOUT_DATABASE_ID=your_about_database_id_32_chars
NOTION_RESUME_NARRATIVE_DATABASE_ID=your_resume_narrative_db_32_chars

# ============================================
# OPTIONAL - Google Analytics 4
# ============================================
NEXT_PUBLIC_GA_ID=G-
